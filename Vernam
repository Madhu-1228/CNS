import java.util.*;

public class abc {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        String text = sc.nextLine();
        String key = sc.nextLine();

        String result = "";

        // Encryption / Decryption (same logic)
        for (int i = 0; i < text.length(); i++) {
            result += (char)(text.charAt(i) ^ key.charAt(i % key.length()));
        }

        System.out.println("Encrypted: " + result);

        // Decrypt again using same operation
        String original = "";
        for (int i = 0; i < result.length(); i++) {
            original += (char)(result.charAt(i) ^ key.charAt(i % key.length()));
        }

        System.out.println("Decrypted: " + original);

        sc.close();
    }
}
